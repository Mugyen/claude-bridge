doctor() {
  echo ""
  echo "claude-bridge doctor (repo v$VERSION)"
  echo "===================="
  echo ""
  echo "Prerequisites:" ; check_prereqs || true
  echo "" ; echo "Claude Code wiring:" ; check_hooks || true; check_mcp || true; check_skill || true
  echo "" ; echo "Bridge server:"
  # Liveness from /health/ping (source of truth); PID is best-effort (lsof is blind
  # on some hosts). Don't say "not running" just because we couldn't get a PID.
  local listener; listener=$(port_listener_pid "$PORT")
  if curl -sf --max-time 1 "http://localhost:$PORT/health/ping" >/dev/null 2>&1; then
    ok "Running (PID ${listener:-?}, port $PORT)"
    # Stale-code check: code changed after the bridge started? (pull ≠ restart, OPS-4)
    if [ -f "$PID_FILE" ] && [ "$(_mtime "$REPO_DIR/bridge-server.mjs")" -gt "$(_mtime "$PID_FILE")" ]; then
      warn "Running bridge is OLDER than bridge-server.mjs — run 'claude-bridge restart' to apply the latest code"
    fi
  elif [ -n "$listener" ]; then
    fail "Port $PORT held by PID $listener but not serving — 'claude-bridge restart --force' to replace"
  else
    warn "Not running — 'claude-bridge start'"
  fi
  echo "" ; echo "Federation:"
  local ping role; ping=$(curl -sf --max-time 1 "http://localhost:${PORT}/health/ping" 2>/dev/null || true)
  role=$(echo "$ping" | jq -r '.role // empty' 2>/dev/null)
  local drole; drole=$(cat "$ROLE_FILE" 2>/dev/null || echo "standalone")
  if [ -n "$role" ] && [ "$role" != "$drole" ]; then
    fail "Drift: dotfile role='$drole' but the RUNNING bridge is '$role' — a config change didn't take. Run 'claude-bridge restart'."
  else
    ok "Role: ${role:-$drole}${ping:+ (live)}"
  fi
  local drinfo
  drinfo=$(room_api GET /room/info 2>/dev/null || true)
  if printf '%s' "$drinfo" | jq -e '.ok' >/dev/null 2>&1; then
    ok "Room: $(printf '%s' "$drinfo" | jq -r '.room | "\"\(.name)\" (\(.members|length) members)"') — member-token auth active"
  fi
  if [ "$drole" = "spoke" ]; then
    # P2P spoke: the local forwarder is the road to the hub — if it died (reboot,
    # crash), every reconnect attempt is ECONNREFUSED until the user re-joins.
    if [ -s "$SPOKE_PIPE_TICKET_FILE" ]; then
      if [ -f "$SPOKE_PIPE_PID_FILE" ] && kill -0 "$(cat "$SPOKE_PIPE_PID_FILE" 2>/dev/null)" 2>/dev/null; then
        ok "p2p forwarder up (ticket $(cut -c1-16 "$SPOKE_PIPE_TICKET_FILE" 2>/dev/null)…)"
      else
        fail "p2p forwarder DOWN — hub unreachable. Re-join: claude-bridge join 'p2p:$(cat "$SPOKE_PIPE_TICKET_FILE")#<token>'"
      fi
    fi
    local hub; hub=$(cat "$HUB_FILE" 2>/dev/null)
    if [ -n "$hub" ] && curl -sf --max-time 6 "${hub}/health/ping" >/dev/null 2>&1; then ok "Hub reachable: $hub"
    elif [ -n "$hub" ]; then warn "Hub NOT reachable: $hub (outage, or tunnel down on the hub)"; fi
  fi
  if [ "$drole" = "hub" ]; then
    local dprov; dprov=$(cat "$TUNNEL_PROVIDER_FILE" 2>/dev/null || echo "tunnel")
    if [ "$dprov" = "tailscale" ]; then
      if tailscale serve status 2>/dev/null | grep -q ":${FED_PORT}"; then ok "EXPOSED via tailscale: $(cat "$TUNNEL_URL_FILE" 2>/dev/null)"
      else warn "Hub mode but tailscale serve is not forwarding :${FED_PORT} — 'claude-bridge share --tailscale' to re-open"; fi
    elif [ -f "$TUNNEL_PID_FILE" ] && kill -0 "$(cat "$TUNNEL_PID_FILE" 2>/dev/null)" 2>/dev/null; then ok "EXPOSED via $dprov: $(cat "$TUNNEL_URL_FILE" 2>/dev/null)"
    else warn "Hub mode but no tunnel process — 'claude-bridge share' to (re)open one"; fi
  fi
  echo "" ; echo "Ports:"
  # lsof is absent on some hosts (exit-127 noise) — count via lsof when present,
  # else degrade to a single-listener presence check via port_listener_pid (ss).
  local n
  if command -v lsof >/dev/null 2>&1; then
    # `|| true`: lsof exits 1 on no-match, and set -e + pipefail would kill doctor.
    n=$(lsof -ti:"$PORT" -sTCP:LISTEN 2>/dev/null | sort -u | wc -l | tr -d ' ' || true)
    [ "$n" -le 1 ] && ok "Port $PORT: ${n} listener" || fail "Port $PORT: $n listeners (conflict!)"
  elif [ -n "$(port_listener_pid "$PORT")" ]; then
    ok "Port $PORT: listener present (no lsof — count unavailable, used ss)"
  else
    ok "Port $PORT: no listener"
  fi
  echo "" ; echo "Recent CLI errors:"
  if [ -f "$CLI_LOG" ]; then grep -E '→ (FAIL|error)' "$CLI_LOG" 2>/dev/null | tail -3 | sed 's/^/    /' || true; ok "log: $CLI_LOG"; else ok "no CLI log yet"; fi
  echo ""
}

health_cmd() {
  echo ""
  echo "claude-bridge health (repo v$VERSION)"
  echo "===================="
  echo ""
  # Liveness is decided ONLY by /health/ping — the source of truth. Do NOT gate on
  # lsof finding a listener PID: lsof is blind to the socket on some hosts (the VM),
  # which made health falsely report "not running" while the bridge was up + serving.
  if ! curl -sf --max-time 2 "http://localhost:$PORT/health/ping" >/dev/null 2>&1; then
    fail "Bridge not running on port $PORT — start it with 'claude-bridge start'"
    return 1
  fi
  local listener; listener=$(port_listener_pid "$PORT"); [ -z "$listener" ] && listener="?"
  ok "Running — PID $listener · port $PORT · log /tmp/claude-bridge-server.log"

  # Full /health is token-gated when sharing is on, so send the token if we have
  # one. (Falls back to the ungated ping if the full view is unavailable.)
  local token resp
  token=$(cat "$TOKEN_FILE" 2>/dev/null || true)
  if [ -n "$token" ]; then
    resp=$(curl -sf --max-time 2 -H "X-Bridge-Token: $token" "http://localhost:$PORT/health" 2>/dev/null || true)
  else
    resp=$(curl -sf --max-time 2 "http://localhost:$PORT/health" 2>/dev/null || true)
  fi
  if [ -z "$resp" ]; then
    warn "Full /health unavailable (gated, and no/!wrong token) — ping only:"
    curl -sf "http://localhost:$PORT/health/ping" 2>/dev/null | jq . 2>/dev/null || true
    return 0
  fi

  local role node tok
  role=$(echo "$resp" | jq -r '.role'); node=$(echo "$resp" | jq -r '.node')
  [ -n "$token" ] && tok="yes" || tok="no"   # /health has no .sharing field; the token file is the source of truth
  echo ""
  echo "Topology:"
  ok "Role: $role · Node: $node · Token configured: $tok"
  # The local rooms store holds rooms WE host. Show it as the live room ONLY when
  # we're actually hosting (role=hub). A machine can own a paused room AND be a
  # spoke in someone else's room — showing the owned one as a spoke is misleading
  # (that was the bug). When a spoke, the owned room is just dormant → a hint.
  local rinfo own_room=""
  rinfo=$(room_api GET /room/info 2>/dev/null || true)
  own_room=$(printf '%s' "$rinfo" | jq -r 'if .ok then .room.name else empty end' 2>/dev/null)
  if [ "$role" = "hub" ] && [ -n "$own_room" ]; then
    ok "Room (hosting): $(printf '%s' "$rinfo" | jq -r '.room | "\"\(.name)\" — \(.members|length) member(s), \(.invites|length) open invite(s), password \(if .password_set then "on" else "off" end)"')"
  fi
  if [ "$role" = "spoke" ]; then
    local hub rname; hub=$(cat "$HUB_FILE" 2>/dev/null || true); rname=$(cat "$SPOKE_ROOM_FILE" 2>/dev/null || true)
    local rlabel; rlabel=$([ -n "$rname" ] && echo "room \"$rname\"" || echo "a room")
    if [ -n "$hub" ]; then
      if curl -sf --max-time 6 "$hub/health/ping" >/dev/null 2>&1; then ok "In $rlabel (member, as \"$node\") — reachable"
      else warn "In $rlabel (member, as \"$node\") — NOT reachable (owner offline or tunnel down)"; fi
    fi
    [ -n "$own_room" ] && warn "You also OWN a paused room \"$own_room\" (not hosting now) — see: claude-bridge room list"
  elif [ "$role" = "hub" ]; then
    # Tunnel: URL + whether the cloudflared PROCESS is alive + whether the URL is
    # actually reachable end-to-end. (Previously only printed the recorded URL, so
    # a dead/flapping tunnel looked the same as a healthy one.)
    local turl tpid tprov
    turl=$(cat "$TUNNEL_URL_FILE" 2>/dev/null || true)
    tpid=$(cat "$TUNNEL_PID_FILE" 2>/dev/null || true)
    tprov=$(cat "$TUNNEL_PROVIDER_FILE" 2>/dev/null || echo "tunnel")
    if [ -z "$turl" ]; then
      warn "Tunnel: none recorded — hub isn't exposed. Run: claude-bridge share"
    else
      if [ "$tprov" = "tailscale" ]; then
        if tailscale serve status 2>/dev/null | grep -q ":${FED_PORT}"; then ok "EXPOSED via tailscale: $turl"
        else fail "Share URL: $turl"; fail "tailscale serve is NOT forwarding :${FED_PORT} — re-run share --tailscale"; fi
      elif [ -n "$tpid" ] && kill -0 "$tpid" 2>/dev/null; then ok "EXPOSED via $tprov: $turl"; ok "Share process: UP ($tprov PID $tpid)"
      else fail "Share URL: $turl"; fail "Share process: DOWN ($tprov not running) — re-run share"; fi
      # End-to-end reachability (the real test) — only meaningful for http(s) URLs;
      # a p2p ticket is verified on the SPOKE side (its local forwarder), not here.
      case "$turl" in
        http://*|https://*)
          if curl -sf --max-time 8 "$turl/health/ping" >/dev/null 2>&1; then ok "Share reachable: $turl/health/ping → 200"
          else fail "Share NOT reachable: $turl returns an error (530/timeout) — spokes can't connect"; fi ;;
        p2p:*)
          ok "p2p share: spokes verify reachability via their local forwarder (doctor on the spoke)" ;;
      esac
    fi
    # Member machines from the ROOM (link-based) — a joined machine shows here
    # even with zero active sessions (session-derived lists miss those). Falls
    # back to the session-derived view if there's no room (legacy hub).
    local rinfo; rinfo=$(room_api GET /room/info 2>/dev/null)
    if printf '%s' "$rinfo" | jq -e '.ok' >/dev/null 2>&1; then
      echo "  Room members (machines):"
      printf '%s' "$rinfo" | jq -r '.room.members[] | "    \(if .online then "●" else "○" end) \(.node)\(if .role=="owner" then " [you, owner]" else "" end)"' 2>/dev/null
    else
      local spokes; spokes=$(echo "$resp" | jq -r '[.sessions[]?|.node]|map(select(.!="local" and .!=null))|unique|.[]' 2>/dev/null || true)
      if [ -n "$spokes" ]; then echo "  Connected machines:"; echo "$spokes" | sed 's/^/    • /'
      else warn "No other machines connected"; fi
    fi
  fi

  echo ""
  echo "Registered clients ($(echo "$resp" | jq -r '.sessions|length') session(s)):"
  echo "$resp" | jq -r '.sessions[]? | "  • \(.name)\(if (.node // "local") != "local" then " @\(.node)" else "" end)\(if (.description // "") != "" then " — \(.description)" else "" end)"' 2>/dev/null || true

  echo ""
  echo "Messages:"
  ok "pending $(echo "$resp" | jq -r '.pending') · answered $(echo "$resp" | jq -r '.answered') · notices $(echo "$resp" | jq -r '.notices')"
  echo ""
}

