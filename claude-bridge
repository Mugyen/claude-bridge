# Apply the core install steps (used by `install` and `update`).
run_install_steps() {
  chmod +x "$REPO_DIR"/hooks/*.sh
  manifest_init
  write_version
  manifest_add FILE "$TOKEN_FILE"; manifest_add FILE "$ROLE_FILE"; manifest_add FILE "$HUB_FILE"; manifest_add FILE "$NODE_FILE"
  # The hooks/MCP/skill/Desktop steps all wire into the Claude Code CLI — skip
  # them on a headless hub/server node (no `claude`), but still install the
  # CLI-on-PATH so the box can be driven with `claude-bridge start/share/doctor`.
  # `update` reaches here WITHOUT check_prereqs, so derive HAS_CLAUDE if unset —
  # otherwise the old `:-1` default made headless `update` crash on `claude mcp`.
  if [ -z "${HAS_CLAUDE:-}" ]; then
    if command -v claude &>/dev/null; then HAS_CLAUDE=1; else HAS_CLAUDE=0; fi
  fi
  if [ "${HAS_CLAUDE:-1}" = 1 ]; then
    install_hooks; install_mcp; install_skill; remove_claude_md_legacy
    install_desktop
  else
    ok "Server/hub-only: skipped hooks, MCP, skill, Desktop (no Claude Code CLI here)"
  fi
  symlink_cli
}

# ── Main ────────────────────────────────────────────────────────────────────

CLI_ARGS="${*:2}"
# Log every invocation (success OR failure) to ~/.claude/claude-bridge.log.
# Log every invocation AND preserve the real exit code — without re-exiting, a
# command's `return 1` (e.g. `health` when the bridge is down) gets clobbered by
# log_action's own status, so `if claude-bridge health` would misread success.
trap 'rc=$?; log_action "exit:$rc"; exit $rc' EXIT
case "$ACTION" in
  install)
    echo ""
    echo "claude-bridge installer (v$VERSION)"
    echo "==================="
    echo ""
    echo "Checking prerequisites..."
    if ! check_prereqs; then
      echo ""
      fail "Missing prerequisites. Install them and try again."
      exit 1
    fi
    echo ""
    echo "Installing..."
    run_install_steps   # hooks, MCP, skill, Desktop, version/manifest, + the claude-bridge CLI on PATH
    echo ""
    echo "Done! Next:"
    echo ""
    echo "  claude-bridge start      # start the bridge"
    echo "  claude-bridge doctor     # full health check"
    echo "  claude-bridge help       # all commands"
    echo ""
    echo "Already-open Claude sessions need a restart to pick up the MCP server."
    echo "CLI sessions auto-register; Desktop needs a relaunch."
    echo ""
    ;;

  uninstall)
    echo ""
    echo "claude-bridge uninstaller (running v$VERSION)"
    echo "====================="
    echo ""
    warn "Full teardown: this removes all config AND stops the running bridge."
    warn "Connected Claude sessions will be disconnected. If you're running this"
    warn "FROM a session bound to the bridge, run it from a SEPARATE terminal instead."
    echo ""

    # Detect prior installed version
    if [ -f "$VERSION_FILE" ]; then
      PRIOR=$(cat "$VERSION_FILE")
      echo "Detected prior install: v$PRIOR"
    else
      echo "No version marker found — running full cleanup of all known artifacts"
    fi
    echo ""

    echo "Manifest-tracked artifacts:"
    if ! manifest_uninstall; then
      warn "No manifest found (this is an old install or fresh checkout)"
    fi
    echo ""

    # Always run the full known-cleanup steps too — covers anything the
    # manifest missed and handles installs that predate manifest tracking.
    echo "Standard cleanup (hooks, MCP, legacy docs, Desktop, temp):"
    remove_hooks
    remove_mcp
    remove_skill
    remove_claude_md_legacy
    remove_desktop
    # Federation config files (hardcoded fallback in case the manifest is missing).
    rm -f "$TOKEN_FILE" "$ROLE_FILE" "$HUB_FILE" "$NODE_FILE" "$P2P_KEY_FILE" "$EXPOSE_FILE" "$ROOM_KEY_FILE" "$CODES_FILE" "$HOME/.claude/.cc-bridge-rendezvous" && ok "Federation config removed (token, role, hub, node, p2p key, expose policy, room key, codes)"
    # Remove the claude-bridge CLI symlink from PATH (manifest handles the tracked
    # one; this hardcoded fallback covers both install locations).
    UNSUDO="sudo"; [ -t 0 ] || UNSUDO="sudo -n"   # never hang on a password prompt non-interactively
    for cli in /usr/local/bin/claude-bridge "$HOME/.local/bin/claude-bridge"; do
      if [ -L "$cli" ] || [ -e "$cli" ]; then
        rm -f "$cli" 2>/dev/null || { command -v sudo >/dev/null 2>&1 && $UNSUDO rm -f "$cli" 2>/dev/null; }
        [ -e "$cli" ] && warn "Could not remove $cli (run: sudo rm -f $cli)" || ok "Removed CLI symlink: $cli"
      fi
    done
    # Capture runtime PIDs BEFORE we wipe the /tmp markers that record them.
    tunnel_pid=$(cat "$TUNNEL_PID_FILE" 2>/dev/null || echo "")
    pipe_pid=$(cat "$SPOKE_PIPE_PID_FILE" 2>/dev/null || echo "")
    tunnel_prov=$(cat "$TUNNEL_PROVIDER_FILE" 2>/dev/null || echo "")
    rm -f "$TUNNEL_PID_FILE" "$TUNNEL_URL_FILE" "$TUNNEL_PROVIDER_FILE" \
          "$SPOKE_PIPE_PID_FILE" "$SPOKE_PIPE_PORT_FILE" "$SPOKE_PIPE_TICKET_FILE"
    if [ "$TUNNEL_PID_FILE" = "/tmp/claude-bridge-tunnel.pid" ]; then
      # Real uninstall: full wipe. When the tunnel paths are env-overridden (a
      # TEST is running uninstall against scratch state), SKIP the global glob —
      # it nuked a live production share's state files and the captured-PID kill
      # below took out the real dumbpipe (field incident 2026-06-10, second of
      # its class after the test-share-flags one; see DEVELOPER.md lesson #15).
      rm -f /tmp/claude-bridge-* /tmp/cc-bridge-* /tmp/claude-bridge.pid /tmp/cc-bridge.pid
      ok "Temp files cleaned (/tmp/{claude,cc}-bridge-* incl. session state + pid/url)"
    else
      ok "Temp files cleaned (scoped — tunnel paths env-overridden, global /tmp wipe skipped)"
    fi
    rm -f "$VERSION_FILE"

    # FINAL step — full teardown: close the tunnel, then stop the running bridge.
    # Done LAST so that if this is run from a session bound to the bridge, the
    # disconnect can only land AFTER every other cleanup step has completed.
    if [ -n "$tunnel_pid" ] && kill -0 "$tunnel_pid" 2>/dev/null; then
      kill "$tunnel_pid" 2>/dev/null && ok "Closed federation tunnel (PID $tunnel_pid)" || true
    fi
    if [ -n "$pipe_pid" ] && kill -0 "$pipe_pid" 2>/dev/null; then
      kill "$pipe_pid" 2>/dev/null && ok "Closed p2p forwarder (PID $pipe_pid)" || true
    fi
    # tailscale serve config persists across reboots — tear it down if we set it up.
    if [ "$tunnel_prov" = "tailscale" ] && command -v tailscale &>/dev/null; then
      tailscale serve --tcp "${FED_PORT}" off 2>/dev/null && ok "tailscale serve for :${FED_PORT} removed" || true
    fi
    listener=$(port_listener_pid "$PORT")   # lsof→ss fallback (lsof absent on some hosts)
    if [ -n "$listener" ]; then
      warn "Stopping the running bridge (PID $listener) — connected sessions will disconnect"
      kill "$listener" 2>/dev/null || true          # SIGTERM → graceful SSE close in the server
      for _ in 1 2 3 4 5 6; do kill -0 "$listener" 2>/dev/null || break; sleep 0.3; done
      kill -0 "$listener" 2>/dev/null && { kill -9 "$listener" 2>/dev/null || true; }
      if [ -n "$(port_listener_pid "$PORT")" ]; then
        warn "Bridge still on :$PORT — stop it manually:  kill \$(port pid via lsof/ss)"
      else
        ok "Bridge stopped (port $PORT free)"
      fi
    else
      ok "No running bridge on port $PORT"
    fi
    echo ""
    echo "Done — config removed, bridge stopped, everything cleared."
    echo "Relaunch Claude Desktop app if it was configured."
    echo ""
    ;;

  check)
    echo ""
    echo "claude-bridge status (repo v$VERSION)"
    echo "================"
    echo ""
    if [ -f "$VERSION_FILE" ]; then
      INSTALLED=$(cat "$VERSION_FILE")
      if [ "$INSTALLED" = "$VERSION" ]; then
        ok "Installed version: v$INSTALLED (matches repo)"
      else
        warn "Installed version: v$INSTALLED (repo is v$VERSION — re-run install to upgrade)"
      fi
    else
      warn "No version marker — install may predate manifest tracking, or never installed"
    fi
    echo ""
    echo "Prerequisites:"
    check_prereqs || true
    echo ""
    echo "Claude Code CLI:"
    check_hooks || true
    check_mcp || true
    check_skill || true
    echo ""
    echo "Claude Desktop App:"
    check_desktop
    echo ""
    echo "Server:"
    check_bridge
    echo ""
    ;;

  start)
    start_bridge
    ;;

  stop)
    warn "Stopping the bridge disconnects every Claude session whose MCP client is on it —"
    warn "including the session running this command. Run this from a SEPARATE terminal, not"
    warn "from a Claude session bound to this bridge. (See DEVELOPER.md lesson #23.)"
    stop_bridge
    ;;

  restart)
    warn "Restarting the bridge disconnects every Claude session whose MCP client is on it —"
    warn "including the session running this command, which the harness may then kill. Run this"
    warn "from a SEPARATE terminal, not from a Claude session bound to this bridge. (lesson #23)"
    stop_bridge
    start_bridge
    ;;

  join)
    echo ""
    echo "claude-bridge join (enter a room)"
    echo "================================="
    echo ""
    # support: join '<link>' [--node <id>] [--password [value]]
    ARG3_NODE=""; JOIN_PW_MODE=0; JOIN_PASSWORD=""; JOIN_EXPOSE=""
    _ja=("$@"); _ji=2   # skip 'join' and the link
    while [ $_ji -lt ${#_ja[@]} ]; do
      case "${_ja[$_ji]}" in
        --node) _ji=$((_ji+1)); ARG3_NODE="${_ja[$_ji]:-}" ;;
        --expose) _ji=$((_ji+1)); JOIN_EXPOSE="${_ja[$_ji]:-}" ;;
        --password)
          JOIN_PW_MODE=1
          _jn="${_ja[$((_ji+1))]:-}"
          case "$_jn" in ""|--*) ;; *) _ji=$((_ji+1)); JOIN_PASSWORD="$_jn" ;; esac ;;
      esac
      _ji=$((_ji+1))
    done
    case "$JOIN_EXPOSE" in
      "") ;;
      all|none)
        printf '%s' "$JOIN_EXPOSE" > "$EXPOSE_FILE"
        [ "$JOIN_EXPOSE" = "none" ] && warn "Privacy-first join: your sessions stay HIDDEN from the room until you run: claude-bridge expose <name>" ;;
      *) fail "--expose takes 'all' or 'none'"; exit 1 ;;
    esac
    join_hub "$ARG2"
    ;;

  room)
    room_cmd "$ARG2" "${@:3}"
    ;;

  node)
    node_cmd "$ARG2"
    ;;

  sessions)
    sessions_cmd
    ;;

  expose)
    expose_cmd "$ARG2" true expose
    ;;

  hide)
    expose_cmd "$ARG2" false hide
    ;;

  doctor)
    doctor
    ;;

  health)
    health_cmd
    ;;

  debug)
    debug_cmd
    ;;

  update)
    do_update "$ARG2"
    ;;

  logs)
    show_logs "$@"
    ;;

  version)
    show_version
    ;;

  help)
    print_help
    ;;
esac
